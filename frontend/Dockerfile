FROM node:18-alpine

WORKDIR /app

COPY package*.json ./
RUN npm install

COPY . .

ARG VITE_PTP_PUBLIC_ALPHA_MODE=true
ARG VITE_PTP_ENABLE_MIXED_RUNS=false
ARG VITE_PTP_ENABLE_SELF_APM=false
ARG VITE_PTP_ENABLE_DYNAMIC_K6_CONTROL=false
ARG VITE_PTP_ENABLE_AI_FEATURES=false
ARG VITE_PTP_ENABLE_PLANS=true
ARG VITE_PTP_ENABLE_PLAN_RUNS=true
ARG VITE_PTP_ENABLE_TREND_ANALYSIS=false
ENV VITE_PTP_PUBLIC_ALPHA_MODE=${VITE_PTP_PUBLIC_ALPHA_MODE}
ENV VITE_PTP_ENABLE_MIXED_RUNS=${VITE_PTP_ENABLE_MIXED_RUNS}
ENV VITE_PTP_ENABLE_SELF_APM=${VITE_PTP_ENABLE_SELF_APM}
ENV VITE_PTP_ENABLE_DYNAMIC_K6_CONTROL=${VITE_PTP_ENABLE_DYNAMIC_K6_CONTROL}
ENV VITE_PTP_ENABLE_AI_FEATURES=${VITE_PTP_ENABLE_AI_FEATURES}
ENV VITE_PTP_ENABLE_PLANS=${VITE_PTP_ENABLE_PLANS}
ENV VITE_PTP_ENABLE_PLAN_RUNS=${VITE_PTP_ENABLE_PLAN_RUNS}
ENV VITE_PTP_ENABLE_TREND_ANALYSIS=${VITE_PTP_ENABLE_TREND_ANALYSIS}

RUN npx tsc && npx vite build

FROM nginx:alpine

COPY --from=0 /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 3000

CMD ["nginx", "-g", "daemon off;"]
