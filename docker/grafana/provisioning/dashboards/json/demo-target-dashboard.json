{
  "uid": "demo-target-dashboard",
  "title": "Demo Target Service Dashboard",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Data Source",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "selected": false,
          "text": "Prometheus",
          "value": "Prometheus"
        }
      },
      {
        "name": "job",
        "label": "Job",
        "type": "textbox",
        "query": "demo-target",
        "current": {
          "selected": true,
          "text": "demo-target",
          "value": "demo-target"
        }
      },
      {
        "name": "target_instance",
        "label": "Demo Target",
        "type": "textbox",
        "query": ".*",
        "current": {
          "selected": true,
          "text": ".*",
          "value": ".*"
        }
      },
      {
        "name": "instance",
        "label": "Instance",
        "type": "textbox",
        "query": ".*",
        "current": {
          "selected": true,
          "text": ".*",
          "value": ".*"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Service Up",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(up{job=~\"$job\", target_instance=~\"$target_instance\", instance=~\"$instance\"})",
          "legendFormat": "up"
        }
      ],
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "HTTP TPS",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(target_service_http_requests_total{job=~\"$job\", target_instance=~\"$target_instance\", instance=~\"$instance\"}[$__rate_interval]))",
          "legendFormat": "http tps"
        }
      ],
      "gridPos": {
        "h": 5,
        "w": 5,
        "x": 4,
        "y": 0
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "gRPC TPS",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(target_service_grpc_requests_total{job=~\"$job\", target_instance=~\"$target_instance\", instance=~\"$instance\"}[$__rate_interval]))",
          "legendFormat": "grpc tps"
        }
      ],
      "gridPos": {
        "h": 5,
        "w": 5,
        "x": 9,
        "y": 0
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Dependency Failures (5m)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(target_service_dependency_checks_total{job=~\"$job\", target_instance=~\"$target_instance\", instance=~\"$instance\", status!=\"ok\"}[5m]))",
          "legendFormat": "failed checks"
        }
      ],
      "gridPos": {
        "h": 5,
        "w": 5,
        "x": 14,
        "y": 0
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Filesystem Used (%)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(100 * target_service_filesystem_used_bytes{job=~\"$job\", target_instance=~\"$target_instance\", instance=~\"$instance\"} / clamp_min(target_service_filesystem_total_bytes{job=~\"$job\", target_instance=~\"$target_instance\", instance=~\"$instance\"}, 1))",
          "legendFormat": "fs used"
        }
      ],
      "gridPos": {
        "h": 5,
        "w": 5,
        "x": 19,
        "y": 0
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "CPU Usage (%)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max by (target_instance) (target_service_process_cpu_percent{job=~\"$job\", target_instance=~\"$target_instance\", instance=~\"$instance\"} or 100 * label_replace(sum by (container_label_com_docker_compose_service) (rate(container_cpu_usage_seconds_total{job=\"cadvisor\", cpu=\"total\", container_label_com_docker_compose_service=\"demo-target\"}[$__rate_interval])), \"target_instance\", \"openloadhub-demo-target\", \"container_label_com_docker_compose_service\", \"demo-target\") / scalar(clamp_min(max(machine_cpu_cores), 1)) or 100 * label_replace(sum by (container_label_com_docker_compose_service) (rate(container_cpu_usage_seconds_total{job=\"cadvisor\", cpu=\"total\", container_label_com_docker_compose_service=~\"demo-target.*\"}[$__rate_interval])), \"target_instance\", \"$1\", \"container_label_com_docker_compose_service\", \"(demo-target.*)\") / scalar(clamp_min(max(machine_cpu_cores), 1)))",
          "legendFormat": "{{target_instance}} cpu"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 5
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Memory Usage (%)",
      "description": "demo-target 进程常驻内存（RSS）占运行时可见总内存的百分比；VMS 不进入主图，避免把虚拟地址空间误读成真实内存占用。",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * target_service_process_resident_memory_bytes{job=~\"$job\", target_instance=~\"$target_instance\", instance=~\"$instance\"} / clamp_min(target_service_runtime_memory_total_bytes{job=~\"$job\", target_instance=~\"$target_instance\", instance=~\"$instance\"}, 1)",
          "legendFormat": "{{target_instance}} rss%"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 5
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Network Receive / Transmit",
      "description": "展示 demo-target 运行时网络 namespace 内的收发字节速率（rx/tx），与压力机监控的网络资源语义保持一致。",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (target_instance) (rate(target_service_network_receive_bytes_total{job=~\"$job\", target_instance=~\"$target_instance\", instance=~\"$instance\"}[$__rate_interval]))",
          "legendFormat": "{{target_instance}} rx"
        },
        {
          "refId": "B",
          "expr": "sum by (target_instance) (rate(target_service_network_transmit_bytes_total{job=~\"$job\", target_instance=~\"$target_instance\", instance=~\"$instance\"}[$__rate_interval]))",
          "legendFormat": "{{target_instance}} tx"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 5
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Disk IO Throughput",
      "description": "展示 demo-target 进程级读写 IO 速率（process io_counters）。这是被测服务自身磁盘活动，不是整机或 Docker VM 总吞吐。",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (target_instance) (rate(target_service_disk_read_bytes_total{job=~\"$job\", target_instance=~\"$target_instance\", instance=~\"$instance\"}[$__rate_interval]))",
          "legendFormat": "{{target_instance}} read"
        },
        {
          "refId": "B",
          "expr": "sum by (target_instance) (rate(target_service_disk_write_bytes_total{job=~\"$job\", target_instance=~\"$target_instance\", instance=~\"$instance\"}[$__rate_interval]))",
          "legendFormat": "{{target_instance}} write"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 13
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "HTTP Request Rate by Route",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (route, method, status) (rate(target_service_http_requests_total{job=~\"$job\", target_instance=~\"$target_instance\", instance=~\"$instance\"}[$__rate_interval]))",
          "legendFormat": "{{method}} {{route}} {{status}}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 13
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "gRPC Request Rate by Method",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (method, status) (rate(target_service_grpc_requests_total{job=~\"$job\", target_instance=~\"$target_instance\", instance=~\"$instance\"}[$__rate_interval]))",
          "legendFormat": "{{method}} {{status}}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 13
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "HTTP Latency",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "1000 * sum(rate(target_service_http_request_duration_seconds_sum{job=~\"$job\", target_instance=~\"$target_instance\", instance=~\"$instance\"}[$__rate_interval])) / clamp_min(sum(rate(target_service_http_request_duration_seconds_count{job=~\"$job\", target_instance=~\"$target_instance\", instance=~\"$instance\"}[$__rate_interval])), 1)",
          "legendFormat": "avg ms"
        },
        {
          "refId": "B",
          "expr": "1000 * histogram_quantile(0.95, sum by (le) (rate(target_service_http_request_duration_seconds_bucket{job=~\"$job\", target_instance=~\"$target_instance\", instance=~\"$instance\"}[$__rate_interval])))",
          "legendFormat": "p95 ms"
        },
        {
          "refId": "C",
          "expr": "1000 * histogram_quantile(0.99, sum by (le) (rate(target_service_http_request_duration_seconds_bucket{job=~\"$job\", target_instance=~\"$target_instance\", instance=~\"$instance\"}[$__rate_interval])))",
          "legendFormat": "p99 ms"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 21
      }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "gRPC Latency",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "1000 * sum(rate(target_service_grpc_request_duration_seconds_sum{job=~\"$job\", target_instance=~\"$target_instance\", instance=~\"$instance\"}[$__rate_interval])) / clamp_min(sum(rate(target_service_grpc_request_duration_seconds_count{job=~\"$job\", target_instance=~\"$target_instance\", instance=~\"$instance\"}[$__rate_interval])), 1)",
          "legendFormat": "avg ms"
        },
        {
          "refId": "B",
          "expr": "1000 * histogram_quantile(0.95, sum by (le) (rate(target_service_grpc_request_duration_seconds_bucket{job=~\"$job\", target_instance=~\"$target_instance\", instance=~\"$instance\"}[$__rate_interval])))",
          "legendFormat": "p95 ms"
        },
        {
          "refId": "C",
          "expr": "1000 * histogram_quantile(0.99, sum by (le) (rate(target_service_grpc_request_duration_seconds_bucket{job=~\"$job\", target_instance=~\"$target_instance\", instance=~\"$instance\"}[$__rate_interval])))",
          "legendFormat": "p99 ms"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 21
      }
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Dependency Check Rate",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (kind, status) (rate(target_service_dependency_checks_total{job=~\"$job\", target_instance=~\"$target_instance\", instance=~\"$instance\"}[$__rate_interval]))",
          "legendFormat": "{{kind}} {{status}}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 29
      }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Dependency Latency (Last Observed)",
      "description": "展示最近一次 dependency probe 的时延。低频 probe 不再使用 rate/histogram quantile，避免面板空白。",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "1000 * target_service_dependency_last_latency_seconds{job=~\"$job\", target_instance=~\"$target_instance\", instance=~\"$instance\"}",
          "legendFormat": "{{kind}} last ms"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 29
      }
    }
  ]
}
