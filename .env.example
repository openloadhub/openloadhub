#############################################
# OpenLoadHub public demo environment template
# Copy to .env for Docker Compose usage.
#
# Full Docker container-internal app links use OPENLOADHUB_DOCKER_*.
# Host mixed-mode uses docs/public/examples/openloadhub-host.env.example instead.
#############################################

# Database
MYSQL_ROOT_PASSWORD=ptp_demo_root
MYSQL_DATABASE=ptp
MYSQL_USER=ptp
MYSQL_PASSWORD=ptp_demo_password
MYSQL_PORT=13306
OPENLOADHUB_DOCKER_DATABASE_URL=mysql+pymysql://ptp:ptp_demo_password@mysql:3306/ptp

# Redis / Celery
REDIS_PORT=16379
OPENLOADHUB_DOCKER_CELERY_BROKER_URL=redis://redis:6379/0
OPENLOADHUB_DOCKER_CELERY_RESULT_BACKEND=redis://redis:6379/1

# Agent
ENABLE_NACOS=0
OPENLOADHUB_DOCKER_AGENT_HOSTS=ptp-agent:9096,ptp-agent-2:9096,ptp-agent-3:9096,ptp-agent-4:9096
AGENT_EXEC_MODE=real
K6_BIN=/usr/local/bin/k6
AGENT_INSTALL_CHROMIUM=0
JMETER_DOWNLOAD_URL=https://archive.apache.org/dist/jmeter/binaries/apache-jmeter-5.4.3.tgz
JMETER_GRPC_PLUGIN_URL=https://github.com/zalopay-oss/jmeter-grpc-request/releases/download/v1.2.6/jmeter-grpc-request.jar

# Application
APP_NAME=OpenLoadHub
OPENLOADHUB_SECRET_KEY=change-me-at-least-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_SECONDS=3600
APP_DEBUG=0
TESTING=0
PTP_PUBLIC_BASE_URL=http://127.0.0.1:13000
ALLOW_SELF_REGISTER=0
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=ptp_demo_admin
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_FULL_NAME=Administrator
DEFAULT_TESTER_USERNAME=demo_tester
DEFAULT_TESTER_PASSWORD=ptp_demo_tester
DEFAULT_TESTER_EMAIL=demo_tester@example.com
DEFAULT_TESTER_FULL_NAME=Demo Tester
BUSINESS_LINES=demo:demo
ENVIRONMENTS=demo:demo:test,testnet:TestNet:testnet,mainnet:主网:main
OPENLOADHUB_DEMO_ENV=demo

# Public alpha feature flags
PTP_PUBLIC_ALPHA_MODE=true
PTP_ENABLE_MIXED_RUNS=false
PTP_ENABLE_SELF_APM=false
PTP_ENABLE_NOTIFICATIONS=false
PTP_ENABLE_ALERTS=false
PTP_ENABLE_PLANS=true
PTP_ENABLE_PLAN_RUNS=true
PTP_ENABLE_TREND_ANALYSIS=false
PTP_ENABLE_AI_FEATURES=false
NOTIFICATION_ENV_LABEL=demo
PTP_WEBHOOK_BOOTSTRAP_FILE=
VITE_PTP_PUBLIC_ALPHA_MODE=true
VITE_PTP_ENABLE_MIXED_RUNS=false
VITE_PTP_ENABLE_SELF_APM=false
VITE_PTP_ENABLE_DYNAMIC_K6_CONTROL=false
VITE_PTP_ENABLE_AI_FEATURES=false
VITE_PTP_ENABLE_PLANS=true
VITE_PTP_ENABLE_PLAN_RUNS=true
VITE_PTP_ENABLE_TREND_ANALYSIS=false

# Observability
OPENLOADHUB_DOCKER_PUSHGATEWAY_URL=http://pushgateway:9091
PUSHGATEWAY_PORT=19091
OPENLOADHUB_DOCKER_PROMETHEUS_URL=http://prometheus:9090
PROMETHEUS_PORT=19090
PROMETHEUS_RETENTION_TIME=24h
OPENLOADHUB_DOCKER_GRAFANA_BASE_URL=http://grafana:3000
GRAFANA_PUBLIC_BASE_URL=http://127.0.0.1:13001
GRAFANA_PROMETHEUS_DATASOURCE_URL=http://prometheus:9090
GRAFANA_INFLUXDB_DATASOURCE_URL=http://influxdb:8086
GRAFANA_INFLUXDB_DATABASE=jmeter
GRAFANA_PORT=13001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=ptp_demo_grafana
REDIS_EXPORTER_PORT=19121
MYSQLD_EXPORTER_PORT=19104
CADVISOR_PORT=18098
K6_HTTP_DASHBOARD_UID=k6-prometheus-ptp
K6_GRPC_DASHBOARD_UID=k6-grpc-ptp
K6_WS_DASHBOARD_UID=21Ev3D0Ik
K6_KAFKA_DASHBOARD_UID=usA2Xd_4z
JMETER_DASHBOARD_UID=jmeter-load-test-influx
POD_DASHBOARD_UID=pod-monitor-dashboard

# InfluxDB
INFLUXDB_PORT=18086
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=ptp_demo_influx
INFLUXDB_TOKEN=ptp_demo_influx_token
INFLUXDB_ORG=ptp
INFLUXDB_BUCKET=jmeter
INFLUXDB_RETENTION=168h
JMETER_INFLUXDB_HOST=influxdb
JMETER_INFLUXDB_PORT=8086
JMETER_INFLUXDB_ORG=ptp
JMETER_INFLUXDB_BUCKET=jmeter
JMETER_INFLUXDB_TOKEN=ptp_demo_influx_token
JMETER_INFLUXDB_HTTP_SCHEME=http

# Public host ports
PTP_FRONTEND_PORT=13000
PTP_ADMIN_PORT=18000
PTP_AGENT_PORT=19096
PTP_AGENT_2_PORT=19097
PTP_AGENT_3_PORT=19098
PTP_AGENT_4_PORT=19099
PTP_WORKER_CONCURRENCY=2
PTP_REPORTS_DIR=/tmp_reports
DEMO_TARGET_HTTP_PORT=18088
DEMO_TARGET_GRPC_PORT=15051
DEMO_TARGET_HTTP_BASE_URL=http://demo-target:8080
DEMO_TARGET_GRPC_ADDRESS=demo-target:50051

# Local cleanup
LOCAL_ARTIFACT_RETENTION_DAYS=7
TMP_REPORT_RETENTION_DAYS=7
