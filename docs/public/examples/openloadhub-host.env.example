###########################################################
# OpenLoadHub public demo host mixed-mode environment
#
# Use this file when host ptp-admin / ptp-worker / frontend
# connect to the public demo compose middleware.
# Do not pass this file to `docker compose -f docker-compose.demo.yml up`;
# full Docker mode uses container-internal defaults instead.
###########################################################

# Public demo MySQL / Redis mapped from docker-compose.demo.yml
MYSQL_ROOT_PASSWORD=ptp_demo_root
MYSQL_DATABASE=ptp
MYSQL_USER=ptp
MYSQL_PASSWORD=ptp_demo_password
MYSQL_PORT=13306
DATABASE_URL=mysql+pymysql://ptp:ptp_demo_password@127.0.0.1:13306/ptp

REDIS_PORT=16379
CELERY_BROKER_URL=redis://127.0.0.1:16379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:16379/1

# Host services and Docker agents
ENABLE_NACOS=0
NACOS_SERVER=127.0.0.1:8848
NACOS_NAMESPACE=default
NACOS_USERNAME=nacos
NACOS_PASSWORD=nacos
AGENT_HOSTS=127.0.0.1:19096,127.0.0.1:19097,127.0.0.1:19098,127.0.0.1:19099
AGENT_EXEC_MODE=real
K6_BIN=/usr/local/bin/k6
AGENT_INSTALL_CHROMIUM=0

# Public demo application flags
APP_NAME=OpenLoadHub
SECRET_KEY=change-me-at-least-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_SECONDS=3600
APP_DEBUG=true
TESTING=0
PTP_PUBLIC_BASE_URL=http://127.0.0.1:13000
ALLOW_SELF_REGISTER=0
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=ptp_demo_admin
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_FULL_NAME=Administrator
DEFAULT_TESTER_USERNAME=demo_tester
DEFAULT_TESTER_PASSWORD=ptp_demo_tester
DEFAULT_TESTER_EMAIL=demo_tester@example.com
DEFAULT_TESTER_FULL_NAME="Demo Tester"
BUSINESS_LINES=demo:demo
ENVIRONMENTS=demo:demo:test,testnet:TestNet:testnet,mainnet:主网:main
OPENLOADHUB_DEMO_ENV=demo

PTP_PUBLIC_ALPHA_MODE=true
PTP_ENABLE_MIXED_RUNS=false
PTP_ENABLE_SELF_APM=false
PTP_ENABLE_NOTIFICATIONS=false
PTP_ENABLE_ALERTS=false
PTP_ENABLE_PLANS=true
PTP_ENABLE_PLAN_RUNS=true
PTP_ENABLE_TREND_ANALYSIS=false
PTP_ENABLE_AI_FEATURES=false
NOTIFICATION_ENV_LABEL=demo
PTP_WEBHOOK_BOOTSTRAP_FILE=
VITE_PTP_PUBLIC_ALPHA_MODE=true
VITE_PTP_ENABLE_MIXED_RUNS=false
VITE_PTP_ENABLE_SELF_APM=false
VITE_PTP_ENABLE_DYNAMIC_K6_CONTROL=false
VITE_PTP_ENABLE_AI_FEATURES=false
VITE_PTP_ENABLE_PLANS=true
VITE_PTP_ENABLE_PLAN_RUNS=true
VITE_PTP_ENABLE_TREND_ANALYSIS=false

# Shared host report directory for ptp-admin and ptp-worker.
# start-host-apps.sh runs admin/worker from backend/*, so this resolves to repo/.tmp.
PTP_REPORTS_DIR=../../.tmp/openloadhub-host-reports
PTP_LOCAL_SCRIPT_MIRROR_DIR=.tmp/openloadhub-host-scripts
PTP_INLINE_ASSET_DISPATCH_MAX_BYTES=2097152
TMP_REPORT_RETENTION_DAYS=7
LOCAL_ARTIFACT_RETENTION_DAYS=7

# Use local file reports/scripts for this host debug profile.
USE_S3=0
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=ptp-scripts
S3_REGION=us-east-1
S3_ENDPOINT=http://127.0.0.1:9000
S3_RUN_ARTIFACT_PREFIX=runs
S3_REPORT_ARTIFACT_PREFIX=reports
S3_ARTIFACT_RETENTION_DAYS=30
S3_LIFECYCLE_PREFIXES=runs/,reports/

# Observability ports mapped by docker-compose.demo.yml
PUSHGATEWAY_URL=http://127.0.0.1:19091
PROMETHEUS_URL=http://127.0.0.1:19090
PROMETHEUS_RETENTION_TIME=24h
PROMETHEUS_RETENTION_SIZE=2GB
GRAFANA_BASE_URL=http://127.0.0.1:13001
GRAFANA_PUBLIC_BASE_URL=http://127.0.0.1:13001
GRAFANA_PROMETHEUS_DATASOURCE_URL=http://prometheus:9090
GRAFANA_INFLUXDB_DATASOURCE_URL=http://influxdb:8086
GRAFANA_INFLUXDB_DATABASE=jmeter
GRAFANA_PORT=13001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=ptp_demo_grafana
PUSHGATEWAY_PORT=19091
PROMETHEUS_PORT=19090
INFLUXDB_PORT=18086
INFLUXDB_RETENTION=168h
CADVISOR_PORT=18098

K6_HTTP_DASHBOARD_UID=k6-prometheus-ptp
K6_GRPC_DASHBOARD_UID=k6-grpc-ptp
K6_WS_DASHBOARD_UID=21Ev3D0Ik
K6_KAFKA_DASHBOARD_UID=usA2Xd_4z
JMETER_DASHBOARD_UID=jmeter-load-test-influx
POD_DASHBOARD_UID=pod-monitor-dashboard
